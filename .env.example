# Uygulama
APP_HOST=0.0.0.0
APP_PORT=8080
DEBUG=false

# Veritabanı (aiosqlite async driver zorunlu — sqlite+aiosqlite:/// olmalı)
DATABASE_URL=sqlite+aiosqlite:///./data/vulnscan.db

# Ollama
# Docker kullanıyorsanız: OLLAMA_HOST=http://ollama:11434  (docker-compose otomatik set eder)
# Native çalıştırıyorsanız: OLLAMA_HOST=http://localhost:11434
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
# Daha hafif model: llama3.2:3b (2GB) | mistral:7b (4GB)
OLLAMA_TIMEOUT=120

# Araçlar
# Docker kullanıyorsanız bu değerleri değiştirmenize gerek yok (otomatik ayarlanır)
TOOLS_GO_PATH=/usr/local/go/bin
WORDLISTS_PATH=./data/wordlists
NUCLEI_TEMPLATES_PATH=~/.local/nuclei-templates
SQLMAP_OUTPUT_PATH=./data/sqlmap

# Tarama
MAX_CONCURRENT_SCANS=3
DEFAULT_SCAN_MODE=normal
