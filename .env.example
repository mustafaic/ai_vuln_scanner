# Uygulama
APP_HOST=0.0.0.0
APP_PORT=8080
DEBUG=false

# Veritabanı
DATABASE_URL=sqlite:///./data/vulnscan.db

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=120

# Araçlar
TOOLS_GO_PATH=/usr/local/go/bin
WORDLISTS_PATH=./data/wordlists
NUCLEI_TEMPLATES_PATH=~/.local/nuclei-templates
SQLMAP_OUTPUT_PATH=./data/sqlmap

# Tarama
MAX_CONCURRENT_SCANS=3
DEFAULT_SCAN_MODE=normal
